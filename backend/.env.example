# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env ขึ้น git)

# พอร์ตของ backend
PORT=8787

# API key ของ Claude (จาก https://console.anthropic.com) — เก็บฝั่ง server เท่านั้น
ANTHROPIC_API_KEY=sk-ant-...

# คีย์ลับสำหรับเซ็น JWT — ใส่ค่าสุ่มยาว ๆ (เปลี่ยนก่อนใช้จริง)
JWT_SECRET=change-me-to-a-long-random-string

# ชื่อผู้ใช้/อีเมลที่ให้เป็นแอดมิน (คั่นด้วยจุลภาค) เช่น: yanatib,boss@example.com
ADMIN_EMAILS=yanatib

# จำกัดจำนวนครั้งที่ให้ AI ทำนายต่อคนต่อวัน (0 = ไม่จำกัด)
DAILY_LIMIT=0

# โดเมนหน้าเว็บที่อนุญาตให้เรียก (คั่นด้วยจุลภาค, * = อนุญาตทุกที่ — เหมาะกับตอนทดสอบ)
CORS_ORIGIN=*
